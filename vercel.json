{
  "cleanUrls": true,
  "buildCommand": null,
  "outputDirectory": ".",
  "installCommand": null,
  "functions": {
    "app.js": {
      "includeFiles": [
        "index.html",
        "client.js",
        "styles.css",
        "manifest.webmanifest",
        "icon.svg",
        "sw.js"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/app.js"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
